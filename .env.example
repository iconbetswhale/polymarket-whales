DASHBOARD_REFRESH=15
DASHBOARD_PORT=5000
WALLETS_FILE=wallets.json
DATABASE_PATH=polymarket_tracker.db
# Required on serverless hosts. Neon/Vercel may inject DATABASE_URL automatically.
DURABLE_DATABASE_URL=
SPORTS_ONLY=true
RESOLVE_HOURS=168
MIN_AMERICAN_ODDS=
MAX_AMERICAN_ODDS=
REQUEST_TIMEOUT=15
MAX_RETRIES=3
DEFAULT_BANKROLL=10000
UNIT_PERCENTAGE=0.01
# Release 3 execution controls.
EXECUTION_QUOTE_MAX_AGE_SECONDS=60
EXECUTION_WIDE_SPREAD_FRACTION=0.03
MINIMUM_EDGE_DISCOVERY=0.01
MINIMUM_EDGE_B=0.015
MINIMUM_EDGE_A=0.02
MINIMUM_EDGE_A_PLUS=0.025
# Release 3 portfolio caps as fractions of bankroll.
MAX_SINGLE_POSITION_FRACTION=0.02
MAX_GAME_EXPOSURE_FRACTION=0.025
MAX_TEAM_DAY_EXPOSURE_FRACTION=0.04
MAX_DAILY_EXPOSURE_FRACTION=0.06
MAX_CORRELATED_CLUSTER_FRACTION=0.04
MAX_PROVIDER_EXPOSURE_FRACTION=0.10
ADMIN_PASSWORD=
DISCORD_WEBHOOK_URL=
DISCORD_ALERT_TYPES=new_entry,size_increase,full_exit
DISCORD_MIN_POSITION_USD=0
DISCORD_NOTIFY_ON_INITIAL_SCAN=false
# Model Tracker bot notifications. All values are server-side only.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_TRADE_CHANNEL_ID=
DISCORD_NOTIFICATIONS_ENABLED=false
DISCORD_NOTIFICATION_BATCH_SIZE=10
# SportsGameOdds server-side key used for normalized live NoVIG markets.
NOVIG_ODDS_API_KEY=
NOVIG_ODDS_API_BASE_URL=https://api.sportsgameodds.com/v2
NOVIG_ODDS_CACHE_TTL_SECONDS=45
# ProphetX sandbox Trading API credentials. Keep both keys server-side.
PROPHETX_ACCESS_KEY=
PROPHETX_SECRET_KEY=
PROPHETX_API_BASE_URL=https://api-ss-sandbox.betprophet.co/partner
PROPHETX_TRADE_URL=https://ss-sandbox.betprophet.co/
PROPHETX_CACHE_TTL_SECONDS=30
